NOPE_ENVIRONMENT=development
NOPE_BASE_URL=http://localhost:8000
NOPE_WEB_URL=http://localhost:3000
NOPE_DATABASE_URL=postgresql+psycopg://nope:nope@nope-postgres:5432/nope
NOPE_AUTH_DATABASE_URL=postgresql://nope:nope@nope-postgres:5432/nope
NOPE_REDIS_URL=redis://nope-redis:6379/0
NOPE_MINIO_ENDPOINT=http://nope-minio:9000
NOPE_SESSION_SECRET=development-session-secret-change-me
NOPE_ENCRYPTION_KEY=development-encryption-key-change-me
NOPE_ALLOW_PRIVATE_URL_TARGETS=false
NOPE_ALLOW_LOCALHOST_URL_TARGETS=false
NOPE_AI_PROVIDER=llama.cpp
NOPE_AI_RUNTIME_URL=http://nope-ai:8080
NOPE_AI_MODEL_NAME=qwen3-8b-q4-k-m
NOPE_AI_MODEL_PATH=/models/qwen3-8b-q4_k_m.gguf
NOPE_MODEL_DIR=C:/models/nope
NOPE_QWEN_MODEL_FILE=qwen3-8b-q4_k_m.gguf
NOPE_AI_CONTEXT_LENGTH=8192
NOPE_AI_MAX_OUTPUT_TOKENS=1024
NOPE_AI_TEMPERATURE=0.1
NOPE_AI_TOP_P=0.9
NOPE_AI_GPU_LAYERS=28
NOPE_AI_GPU_MEMORY_TARGET_MB=5120
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL_INTERNAL=http://localhost:8000
MINIO_ROOT_USER=nope
MINIO_ROOT_PASSWORD=nope-development-password
