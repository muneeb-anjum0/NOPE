{
  "version": 1,
  "workflows": [
    {
      "name": "node build",
      "kind": "node",
      "command": "npm run build"
    }
  ],
  "startup": {
    "kind": "node",
    "command": "node server.js",
    "port": 8080,
    "readiness_path": "/"
  },
  "zap": {
    "enabled": true,
    "max_minutes": 1,
    "auth_state": "unauthenticated",
    "target_path": "/"
  }
}
